# Local API preview configuration.
# Copy this to .env.local and fill with your real server-side values.

SONIC_ARTIST_EVENTS_ENABLED=true
SONIC_TICKETMASTER_ENABLED=true
TICKETMASTER_CONSUMER_KEY=
TICKETMASTER_CONSUMER_SECRET=
SONIC_BANDSINTOWN_ENABLED=false
BANDSINTOWN_APP_ID=

# Optional aliases also supported by the app:
# TICKETMASTER_API_KEY=
# TICKETMASTER_DISCOVERY_API_KEY=
# TM_CONSUMER_KEY=
# TM_CONSUMER_SECRET=

# Compliance-first optional integrations.
# Public, no-secret APIs below are enabled by default with cache, limits and User-Agent.
# Keep credentialed/approval-sensitive providers disabled until the project has accepted terms and owns credentials.
SONIC_NEWS_FEED_ENABLED=false
SONIC_NEWS_FEED_ROUTE_ENABLED=true
SONIC_NEWS_USER_AGENT=SonicSearch/1.0 (+https://sonicsearch.app)
SONIC_NEWS_FEED_CACHE_SECONDS=900
SONIC_NEWS_FEED_DAILY_LIMIT=80
SONIC_NEWS_FEED_TIMEOUT_MS=5200

# Optional durable usage store for daily API limits and one-per-user AI image locks.
# Without these, development falls back to in-memory limits.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Server-side track metadata/previews. iTunes Search is public/documented; Deezer stays opt-in.
SONIC_TRACK_METADATA_ENABLED=true
SONIC_DEEZER_ENABLED=false
SONIC_ITUNES_ENABLED=true
SONIC_TRACK_METADATA_DAILY_LIMIT=120
SONIC_TRACK_METADATA_CACHE_SECONDS=3600

# Approval-sensitive search/playback APIs. Keep disabled until you have accepted terms
# and added official project credentials.
SONIC_SOUNDCLOUD_ENABLED=false
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SONIC_SOUNDCLOUD_SEARCH_DAILY_LIMIT=80
SONIC_SOUNDCLOUD_SEARCH_LIMIT=12
SONIC_SOUNDCLOUD_PREVIEW_RESOLVE_LIMIT=12

SONIC_YOUTUBE_ENABLED=false
YOUTUBE_API_KEY=
YOUTUBE_DATA_API_KEY=
SONIC_YOUTUBE_SEARCH_DAILY_LIMIT=80
SONIC_YOUTUBE_SEARCH_LIMIT=5
SONIC_YOUTUBE_QUERY_VARIANTS_LIMIT=2

# Server-side cover art. Uses MusicBrainz + Cover Art Archive with User-Agent, cache and daily limit.
SONIC_COVER_ART_ENABLED=true
SONIC_COVER_ART_DAILY_LIMIT=100
SONIC_COVER_ART_CACHE_SECONDS=86400
SONIC_COVER_ART_TIMEOUT_MS=9000

# Server-side artist profile enrichment with attribution-friendly sources.
SONIC_ARTIST_PROFILE_ENABLED=true
SONIC_MUSICBRAINZ_ENABLED=true
SONIC_WIKIPEDIA_ENABLED=true
SONIC_ARTIST_PROFILE_DAILY_LIMIT=80
SONIC_ARTIST_PROFILE_CACHE_SECONDS=86400
SONIC_REFERENCE_USER_AGENT=SonicSearch/1.0 (+https://sonicsearch.app)

# Optional artist/social taste enrichment. Last.fm needs your own free API key.
SONIC_LASTFM_ENABLED=false
LASTFM_API_KEY=
SONIC_LASTFM_DAILY_LIMIT=80
SONIC_LASTFM_CACHE_SECONDS=86400

# Public internet radio directory by style. No key required; keep backend/cache/limits on.
SONIC_RADIO_BROWSER_ENABLED=true
SONIC_RADIO_BROWSER_DAILY_LIMIT=120
SONIC_RADIO_BROWSER_CACHE_SECONDS=21600
SONIC_RADIO_BROWSER_LIMIT=8

# AI artist bios can use reference APIs only through the backend.
# Discogs is opt-in: enable it only after accepting terms and adding your own token.
SONIC_ARTIST_BIO_ENABLED=true
SONIC_AI_BIO_DAILY_LIMIT=18
SONIC_ARTIST_BIO_REFERENCE_CACHE_SECONDS=86400
SONIC_DISCOGS_ENABLED=false
DISCOGS_USER_TOKEN=
# Optional aliases:
# DISCOGS_TOKEN=
# SONIC_DISCOGS_USER_AGENT=SonicSearch/1.0 (+https://sonicsearch.app)

# Client-side Deezer/Wikipedia/MusicBrainz hydration stays disabled in index.html by default.
# iTunes Search may run in the client because Apple documents JSONP use for websites.
# Prefer backend routes for any provider that needs credentials, approval, custom User-Agent or stricter attribution.

# Supabase/Postgres user database.
# Keep service-role keys out of frontend. Use service role only as backend/server env.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SONIC_SOCIAL_ENABLED=false
SONIC_CATALOG_EXTRA_ENABLED=false
SONIC_CATALOG_ENRICHMENT_ENABLED=false
