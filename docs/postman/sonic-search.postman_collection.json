{
  "info": {
    "_postman_id": "1c75f84b-b5f1-47e9-a8ab-e6685f0fb686",
    "name": "Sonic Search API QA",
    "description": "Production API checks for Sonic Search. Run Core smoke first. Folders marked quota or write should be run intentionally.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"response is not a 5xx server error\", function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});",
          "",
          "const contentType = pm.response.headers.get(\"Content-Type\") || \"\";",
          "if (contentType.includes(\"application/json\")) {",
          "  const json = pm.response.json();",
          "  pm.test(\"no durable rate limit setup blocker\", function () {",
          "    pm.expect(json.error || \"\").to.not.eql(\"durable_rate_limit_required\");",
          "  });",
          "}"
        ]
      }
    }
  ],
